# Copy to .env and adjust. All variables are prefixed with GKE_.

# Google Cloud project that owns the cluster
GKE_PROJECT_ID=my-gcp-project

# Region (regional cluster) or leave and set GKE_ZONE for zonal placement
GKE_LOCATION=europe-west1
GKE_ZONE=europe-west1-b

# Default cluster targeted by CLI operations
GKE_CLUSTER_NAME=primary

# Node pool sizing
GKE_NODE_COUNT=3
GKE_MACHINE_TYPE=e2-standard-4
GKE_MIN_NODES=1
GKE_MAX_NODES=5

# GKE release channel: RAPID | REGULAR | STABLE | UNSPECIFIED
GKE_RELEASE_CHANNEL=REGULAR

# Optional path to a service-account key file (omit to use ADC)
# GKE_CREDENTIALS_FILE=/path/to/service-account.json

# Logging level
GKE_LOG_LEVEL=INFO
